# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://tissueqa:tissueqa_dev@localhost:5433/tissueqa

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480

# ── Extraction — Reducto ──────────────────────────────────────────────────────
REDUCTO_API_KEY=

# ── Evaluation — Anthropic ────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_TEMPERATURE=0.2

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO

# ── Ruleset ───────────────────────────────────────────────────────────────────
RULESET_VERSION=BT-MS-v0.2
